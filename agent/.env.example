# ---- Airbag agent config (copy to .env) ----
# backend: mock (tests) | local (real HTTP to target-app) | gcp (real Cloud Run)
AIRBAG_BACKEND=local
TARGET_BASE_URL=http://localhost:8081
AIRBAG_WEBHOOK_TOKEN=changeme     # shared token for the Cloud Monitoring webhook channel
SENTRY_WEBHOOK_SECRET=
# Gates the /demo/* ACTION endpoints once the dashboard is public (watching stays open).
# Empty -> demo endpoints are open (local). deploy.sh generates one if unset.
AIRBAG_DEMO_TOKEN=

# ---- GCP (gcp backend) ----
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=asia-northeast1
TARGET_SERVICE=airbag-target

# ---- Gemini (AI Studio key). Empty -> deterministic fallback decision. ----
GEMINI_API_KEY=
GEMINI_DECISION_MODEL=gemini-2.5-flash
GEMINI_PATCH_MODEL=gemini-2.5-pro

# ---- GitHub App (fix-PR stretch) ----
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_REPO=JasonYeYuhe/airbag-target-app
